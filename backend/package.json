{
  "name": "store-intelligence-api",
  "version": "1.0.0",
  "description": "Store Intelligence REST API — Express + MongoDB",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "build:pos": "node ../scripts/build_pos_transactions.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "express": "^4.21.2",
    "mongoose": "^8.9.3",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.2",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "collectCoverageFrom": ["src/**/*.js", "!src/index.js"],
    "coverageThreshold": {
      "global": { "statements": 70 }
    }
  }
}
